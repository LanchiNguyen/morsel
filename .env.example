# Morsel — environment.
#
# Set these in Vercel → Project → Settings → Environment Variables (and copy to
# .env.local for local dev). Leave them all unset and the app runs in demo mode
# against the bundled DC/DMV seed — no backend, no keys required.

# ── Live catalog (Google Places API) ─────────────────────────────────────────
# Server-side ONLY (no VITE_ prefix), read by the /api/dishes and /api/photo
# serverless functions. Never exposed to the browser. Enable the "Places API"
# (New) on a Google Cloud project with billing on, then create a key at:
#   https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# Optional: point the app at a different API origin (defaults to same-origin,
# which is what you want on Vercel). Handy if the API is hosted separately.
# VITE_API_BASE=

# ── Accounts + cloud saves (Supabase) ────────────────────────────────────────
# Public client values, safe to ship — row level security (supabase/schema.sql)
# protects the data. Find them in Supabase → Settings → API. Leave unset to keep
# saves on-device (localStorage) with no sign-in.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
